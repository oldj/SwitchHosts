{
  "private": true,
  "name": "switchhosts",
  "version": "5.0.0-beta.25",
  "description": "Switch hosts quickly!",
  "homepage": "https://switchhosts.vercel.app",
  "license": "Apache-2.0",
  "scripts": {
    "pretest": "rimraf ./test/tmp",
    "test": "npm run test:all",
    "test:unit": "vitest --config ./vitest.config.mts --watch=false",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:e2e": "playwright test",
    "test:all": "npm run typecheck && npm run test:unit && npm run test:rust && npm run test:e2e",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"e2e/**/*.{ts,js}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"e2e/**/*.{ts,js}\" --fix",
    "clean:dist": "rimraf ./dist/*",
    "clean:build": "rimraf ./build/*",
    "dev:renderer": "vite --config ./vite.render.config.mts",
    "build:renderer": "vite build --config ./vite.render.config.mts",
    "build:renderer:tauri": "node scripts/sync-tauri-version.mjs && vite build --config ./vite.render.config.mts --outDir ../../build-tauri --emptyOutDir",
    "sort-lang": "node ./scripts/sort-lang.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:info": "tauri info",
    "version": "node scripts/sync-tauri-version.mjs && git add src/version.json src-tauri/tauri.conf.json"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "dayjs": "1.11.20",
    "lodash": "4.18.1",
    "tslib": "2.8.1",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mantine/core": "^9.1.1",
    "@mantine/hooks": "^9.1.1",
    "@mantine/notifications": "^9.1.1",
    "@playwright/test": "^1.59.1",
    "@tabler/icons-react": "3.42.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/react": "^16.3.2",
    "@types/assert": "1.5.11",
    "@types/lodash": "4.17.24",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "11.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "ahooks": "3.9.7",
    "clsx": "2.1.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jotai": "2.20.0",
    "jsdom": "^29.1.1",
    "prettier": "3.8.3",
    "pretty-bytes": "7.1.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-icons": "5.6.0",
    "react-router": "7.15.0",
    "rimraf": "^6.1.3",
    "sass": "1.99.0",
    "smooth-scroll-into-view-if-needed": "2.0.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "8.0.10",
    "vite-plugin-static-copy": "4.1.0",
    "vitest": "^4.1.5"
  }
}
